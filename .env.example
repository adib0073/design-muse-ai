# =============================================================================
# Backend Mode: Choose ONE of the two options below
# =============================================================================

# OPTION 1: Vertex AI (Google Cloud) — recommended, higher quotas
# Set USE_VERTEX_AI=true and configure your GCP project.
# Requires: gcloud auth application-default login
USE_VERTEX_AI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Image edit model fallback order (left to right)
IMAGE_EDIT_MODELS=gemini-2.5-flash-image,gemini-3.1-flash-image-preview

# OPTION 2: AI Studio (API key) — quick start, free tier has low quotas
# Set USE_VERTEX_AI=false and provide your API key from aistudio.google.com
# USE_VERTEX_AI=false
# GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# Google Cloud Storage (optional — falls back to local disk)
# =============================================================================
GCS_BUCKET_NAME=designmuse-assets

# =============================================================================
# Application Settings (local development)
# =============================================================================
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
# Fallback model when Imagen is rate-limited/unavailable
GEMINI_IMAGE_FALLBACK_MODEL=gemini-2.5-flash-image

# =============================================================================
# API Key Protection (optional locally, recommended for Cloud Run)
# =============================================================================
# When set, all /api/* endpoints require X-API-Key header.
# Leave empty or unset for local development (no key required).
# BACKEND_API_KEY=your-secret-key-here

# =============================================================================
# Cloud Run Deployment
# =============================================================================
# CORS_ORIGINS, FRONTEND_URL, and BACKEND_API_KEY are passed automatically
# by deploy.sh. To deploy: ./deploy.sh  (see README for details)

# Optional: Firebase (for auth)
FIREBASE_PROJECT_ID=your-firebase-project-id
